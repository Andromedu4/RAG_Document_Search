APP_NAME="RAG for Document Search"
APP_ENV=local
DEBUG=false

# Local simple mode. Use SQLite for manual testing without Docker.
DATABASE_URL=sqlite:///./ai_blog.db

# Change in deployed environments.
SECRET_KEY=change-me-use-a-long-random-secret

# Providers: mock, groq, openai
AI_PROVIDER=mock

# OpenAI mode
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_RAG_MODEL=gpt-5.4-nano
OPENAI_SUMMARY_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_DIMENSIONS=1536

# Groq mode. Groq is used for answer generation; embeddings stay local in Groq-only mode.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

CHUNK_MAX_CHARS=1600
CHUNK_OVERLAP_CHARS=220
SEMANTIC_SEARCH_LIMIT=8
RAG_TOP_K=6
UPLOAD_DIR=uploads

# Web URL ingestion
URL_FETCH_TIMEOUT_SECONDS=10
URL_FETCH_MAX_BYTES=1500000
